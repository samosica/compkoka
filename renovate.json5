{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "configMigration": true,
  "timezone": "Asia/Tokyo",
  "schedule": ["every weekend"],
  "labels": ["renovate"],
  "prHourlyLimit": 5,
  "minimumReleaseAge": "7 days",
  "major": {
    "automerge": false,
  },
  "minor": {
    "automerge": false,
  },
  "patch": {
    "automerge": true,
    "platformAutomerge": true,
  },
  "packageRules": [
    {
      "description": "Disable minimum release age check for Docker image digests",
      "matchDatasources": [
        "docker",
      ],
      "matchUpdateTypes": [
        "digest",
      ],
      "minimumReleaseAge": null,
    },
  ],
}
